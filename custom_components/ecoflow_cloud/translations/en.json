    "issues": {
        "ble_wifi_credentials": {
            "title": "Enter Wi-Fi credentials for {device_name}",
            "fix_flow": {
                "step": {
                    "init": {
                        "title": "BLE Wi-Fi recovery credentials",
                        "description": "The device was seen over Bluetooth, but Wi-Fi recovery needs valid credentials. Review the SSID and enter the Wi-Fi password.",
                        "data": {
                            "ble_wifi_ssid": "Wi-Fi SSID",
                            "ble_wifi_password": "Wi-Fi password"
                        }
                    }
                },
                "error": {
                    "missing_credentials": "SSID and password are required."
                },
                "abort": {
                    "entry_missing": "The related config entry is no longer available.",
                    "device_missing": "The related device is no longer available in this config entry."
                },
                "create_entry": {
                    "default": "Wi-Fi credentials saved. BLE recovery will use them on the next retry."
                }
            }
        }
    }
